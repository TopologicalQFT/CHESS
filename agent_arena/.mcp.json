{
  "mcpServers": {
    "chess": {
      "command": "../mcp_bridge/.venv/Scripts/python.exe",
      "args": ["../mcp_bridge/server.py"],
      "env": {
        "PYTHONUTF8": "1",
        "CHESS_SERVER_URL": "ws://localhost:8000/ws"
      }
    },
    "chess-toolkit": {
      "command": "../mcp_bridge/.venv/Scripts/python.exe",
      "args": ["../agent_toolkit/server.py"],
      "env": {
        "PYTHONUTF8": "1"
      }
    }
  }
}
